{
  "name": "claims-assistant",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter api run db:migrate",
    "db:generate": "pnpm --filter api run db:generate",
    "db:studio": "pnpm --filter api run db:studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "@prisma/engines"]
  }
}
